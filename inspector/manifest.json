{
  "manifest_version": 3,
  "name": "Plinth Inspector",
  "description": "DevTools panel for inspecting Webflow Designer internals",
  "version": "0.1.0",
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.design.webflow.com/*",
        "https://webflow.com/design/*"
      ],
      "js": ["content-main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
